$user = "Administrateur"
$pwd = ConvertTo-SecureString "Ekod2025" -AsPlainText -Force
$credlocal = New-Object System.Management.Automation.PSCredential($user,$pwd)
$NomComputer="WIN-K409LHNS7IF"

$newComputerName="WS2022"
$newipaddress="172.16.3.3"
$defaultGateway="172.16.3.1"

$DomainNameDNS="ADE.lan"
$DomainNameNetbios="ADE"
$DomainNameDHCP="ETENDU1"

$userdomain="$DomainNameNetBios\Administrateur"
$creddomain=New-Object System.Management.Automation.PSCredential($userdomain,$pwd)

Invoke-Command -ComputerName $NomComputer -Credential $credlocal -ScriptBlock {
Param($newComputerName, $newipaddress, $defaultGateway)

New-NetIPAddress -InterfaceAlias Ethernet -IPAddress $newipaddress -AddressFamily ipv4 -DefaultGateway $defaultGateway -PrefixLength 24
Disable-NetAdapterBinding -Name Ethernet -ComponentID ms_tcpip6

Rename-Computer -NewName $newComputerName -Restart -Force

} -Asjob -ArgumentList $newComputerName, $newipaddress, $defaultGateway

Start-Sleep -Seconds 60

Invoke-Command -ComputerName $newipaddress -Credential $credlocal -ScriptBlock {
Param($DomainNameDNS, $DomainNameNetbios, $ForestConfiguration)

Install-WindowsFeature -Name AD-Domain-Services, DNS, DHCP -IncludeManagementTools

$ForestConfiguration = @{

'-DatabasePath'= 'C:\Windows\NTDS';
'-DomainMode' = 'Default';
'-DomainName' = $DomainNameDNS;
'-DomainNetbiosName' = $DomainNameNetbios;
'-ForestMode' = 'Default';
'-InstallDns' = $true;
'-LogPath' = 'C:\Windows\NTDS';
'-NoRebootOnCompletion' = $false;
'-SysvolPath' = 'C:\Windows\SYSVOL';
'-CreateDnsDelegation' = $false }

Import-Module ADDSDeployment
Install-ADDSForest @ForestConfiguration -SafeModeAdministratorPassWord (ConvertTo-SecureString "Ekod2025" -AsPlainText -Force) -Force

} -ArgumentList $DomainNameDNS, $DomainNameNetbios, $ForestConfiguration

Read-Host "Appuyer sur ENTREE pour continuer..."

Invoke-Command -ComputerName $newipaddress -Credential $creddomain -ScriptBlock {
Param($DomainNameDHCP)

Add-DhcpServerSecurityGroup
Add-DhcpServerInDC
Restart-Service dhcpserver

Add-DnsServerForwarder -IPAddress "10.72.2.2" -PassThru
Add-DnsServerForwarder -IPAddress "10.72.2.1" -PassThru

Add-DhcpServerv4Scope -Name "$DomainNameDHCP" -StartRange 172.16.3.50 -EndRange 172.16.3.100 -SubnetMask 255.255.255.0
Set-DhcpServerv4OptionValue -ScopeID 172.16.3.0 -OptionId 3 -Value 172.16.3.1
Set-DhcpServerv4OptionValue -ScopeID 172.16.3.0 -OptionId 6 -Value 10.72.2.1
Set-DhcpServerv4OptionValue -ScopeID 172.16.3.0 -OptionId 15 -Value ADE.lan

Set-ItemProperty –Path registry::HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\ServerManager\Roles\12 –Name ConfigurationState –Value 2

New-ADOrganizationalUnit "LE MANS" -Path "DC=ADE,DC=LAN"
New-ADOrganizationalUnit "User" -Path "OU=LE MANS,DC=ADE,DC=LAN"
New-ADUser -Name "Eugéne Hugle" -SamAccountName "E.Hugle" -GivenName "Eugéne"  -Surname "Hugle" -DisplayName "Eugéne Hugle"  -Path "OU=User,OU=LE MANS,DC=ADE,DC=LAN" -Enabled $true  -AccountPassword (ConvertTo-SecureString "Ekod+2025" -AsPlainText -Force) -ChangePasswordAtLogon $true  -PassThru

} -ArgumentList $DomainNameDHCP
